# ── Database ───────────────────────────────────────────────────
# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)

DATABASE_URL=
# ── Frontend (exposed to browser via Vite) ──────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Backend (Auth) ─────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY= # Supabase Service Role Key (kept secure, not exposed to client)

# ── Admin Role ──────────────────────────────────────────────────
OWNER_UNION_ID=          # Supabase User UUID of the app creator; this user gets role "admin" on first login

# ── AI Engine ───────────────────────────────────────────────────
GROQ_API_KEY=
NVIDIA_NIM_API_KEY=

# ── Coral Telemetry Integrations (Optional) ───────────────────
# Keys used by the Coral CLI to query your real software integrations
GITHUB_TOKEN=             # GitHub Personal Access Token (classic) with repo/read:org scope
PAGERDUTY_TOKEN=          # PagerDuty API access key
SENTRY_TOKEN=             # Sentry Auth Token with issues/projects read access
SENTRY_ORG=               # Sentry Organization Slug (found in Sentry URLs)
DATADOG_API_KEY=          # Datadog API Key
DATADOG_APP_KEY=          # Datadog Application Key
SLACK_TOKEN=              # Slack Bot User OAuth Token (xoxb-...)

